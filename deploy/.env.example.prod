# ===== Sieshka PRODUCTION env =====
# Copy to `.env` at the PROJECT ROOT, then `chmod 600 .env`.
# NEVER commit `.env` (already gitignored). `docker compose` reads it for the
# ${VAR} substitution in deploy/docker-compose.prod.yml; the app container also
# receives these via `env_file: .env` from the base compose file.

# --- Postgres (prod overlay overrides the weak default 'sieshka' password) ---
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://sieshka:CHANGE_ME_STRONG_PASSWORD@postgres:5432/sieshka

# --- nano-vm SQLite trace store (mounted at /app/data in container) ---
SQLITE_PATH=/app/data/sieshka_nano_vm.db

# --- Menu timezone (project-specific — NOT Vietnam) ---
MENU_TIMEZONE=Europe/Moscow
MENU_MORNING_END_HOUR=16

# --- LLM providers (M4+) : OpenRouter primary, YandexGPT/GigaChat fallback ---
OPENAI_API_KEY=
OPENAI_API_BASE=https://openrouter.ai/api/v1
YANDEX_API_KEY=
YANDEX_API_BASE=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
YANDEX_MODEL=openai/yandexgpt-pro
GIGACHAT_API_KEY=
GIGACHAT_API_BASE=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_MODEL=openai/GigaChat-Pro

# --- nano-vm-mcp (M3+) ---
NANO_VM_MCP_HOST=localhost
NANO_VM_MCP_PORT=8765

# --- YooKassa (M2+) — RETURN_URL must match the public domain ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://new.siesh-ka.ru/payment/return

# --- Telegram (M2+) ---
TELEGRAM_BOT_TOKEN=

# --- Dashboard auth (M6+) : argon2 hash, NOT plaintext ---
# Generate: python -c "from passlib.context import CryptContext; \
#   print(CryptContext(schemes=['argon2']).hash('your_password'))"
DASHBOARD_USER=admin
DASHBOARD_PASSWORD_HASH=

# --- App ---
DEBUG=false
LOG_LEVEL=INFO
